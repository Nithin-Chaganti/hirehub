        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john.doe.test@example.com\",\n  \"password\": \"StrongPass123\",\n  \"role\": \"candidate\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
