            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/auth/me",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "me"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response has user data', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json.success).to.be.true;",
              "    pm.expect(json.message).to.equal('User fetched successfully');",
              "    pm.expect(json.data).to.have.property('_id');",
              "    pm.expect(json.data).to.have.property('name');",
              "    pm.expect(json.data).to.have.property('email');",
              "    pm.expect(json.data).to.have.property('role');",
              "});",
              "",
              "pm.test('No sensitive fields exposed', function () {",
              "    const data = pm.response.json().data;",
              "    pm.expect(data).to.not.have.property('passwordHash');",
              "    pm.expect(data).to.not.have.property('refreshToken');",
              "    pm.expect(data).to.not.have.property('__v');",
              "});"
            ]
          }
        }
      ]
    },
